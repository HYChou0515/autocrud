# AutoCRUD Web Environment Configuration
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# ============================================================================
# VITE_API_URL - Base URL for all API requests (used by Axios client)
# ============================================================================
# Dev mode:  Relative path, proxied by Vite dev server to avoid CORS.
#            Change to any prefix you like (e.g., /foo/bar).
# Prod mode: Set to your backend URL (e.g., http://server:port)
VITE_API_URL=/api

# ============================================================================
# API_PROXY_TARGET - Vite dev server proxy target (development only)
# ============================================================================
# The actual backend URL that VITE_API_URL/* requests will be forwarded to.
# Only used by Vite dev server — NOT exposed to the browser.
# Example: http://localhost:8000, http://192.168.1.100:8000
API_PROXY_TARGET=http://localhost:8000
